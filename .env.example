# Runtime environment: dev or prod.
APP_ENV=dev
# Log level for structlog output.
LOG_LEVEL=INFO
# PostgreSQL async URL.
DATABASE_URL=postgresql+asyncpg://finassist:finassist@localhost:5432/finassist
# Telegram bot token from BotFather.
TELEGRAM_BOT_TOKEN=replace-me
# Start the Telegram polling loop (disable for API-only runs).
TELEGRAM_POLLING_ENABLED=true
# Comma-separated allowed Telegram user ids.
TELEGRAM_ALLOWED_USER_IDS=123456789
# Pluggy client id.
PLUGGY_CLIENT_ID=replace-me
# Pluggy client secret.
PLUGGY_CLIENT_SECRET=replace-me
# Comma-separated Pluggy item ids to sync.
PLUGGY_ITEM_IDS=replace-me
# Pluggy API base URL.
PLUGGY_BASE_URL=https://api.pluggy.ai
# OpenRouter API key.
OPENROUTER_API_KEY=replace-me
# OpenRouter model id.
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it
# OpenRouter API base URL.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Comma-separated fallback OpenRouter model ids.
OPENROUTER_FALLBACK_MODELS=
# OpenRouter request timeout in seconds.
OPENROUTER_TIMEOUT_SECONDS=90.0
# Maximum OpenRouter SDK retries for transient failures.
OPENROUTER_MAX_RETRIES=2
# OpenRouter transcription model id.
OPENROUTER_TRANSCRIPTION_MODEL=openai/whisper-1
# Liveness window: first message after this many minutes answers from cache and
# triggers a background bank refresh.
SYNC_MAX_AGE_MINUTES=10
# Max seconds to wait for Pluggy to finish a bank refresh before using cached data.
SYNC_REFRESH_TIMEOUT_SECONDS=90
# Seconds between item-status polls while waiting for a bank refresh.
SYNC_REFRESH_POLL_SECONDS=2.0
# Initial sync lookback window in days.
SYNC_INITIAL_LOOKBACK_DAYS=90
# Overlap window for incremental syncs.
SYNC_OVERLAP_DAYS=7
# Maximum LLM tool rounds.
AGENT_MAX_TOOL_ROUNDS=6
# Inbox aggregation window in seconds.
AGENT_DEBOUNCE_SECONDS=2.5
# Agent session lifetime in minutes.
AGENT_SESSION_TTL_MINUTES=360
# Maximum characters retained when replaying a tool result.
AGENT_TOOL_REPLAY_MAX_CHARS=2000
# Maximum number of agent memory entries.
AGENT_MEMORY_LIMIT=50
# Number of prior messages sent to the model, counting all roles including tool rounds.
AGENT_HISTORY_LIMIT=40
# LLM sampling temperature.
AGENT_TEMPERATURE=0.4
# User-facing timezone.
TIMEZONE=America/Sao_Paulo
